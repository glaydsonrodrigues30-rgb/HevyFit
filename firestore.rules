rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default safety catch-all rule: Deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Modern secure helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 'email' in request.auth.token && request.auth.token.email == 'glaydson.rodrigues30@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Validation Helper
    function isValidUser(data) {
      return !('userId' in data) || (data.userId is string && data.userId.size() <= 128);
    }

    // 2. Workout Validation Helper
    function isValidWorkout(data) {
      return !('id' in data) || (data.id is string && data.id.size() <= 128);
    }

    // 3. Routine Validation Helper
    function isValidRoutine(data) {
      return !('id' in data) || (data.id is string && data.id.size() <= 128);
    }

    // 4. WeightEntry Validation Helper
    function isValidWeightEntry(data) {
      return !('id' in data) || (data.id is string && data.id.size() <= 128);
    }

    // 5. Exercise Validation Helper
    function isValidExercise(data) {
      return !('id' in data) || (data.id is string && data.id.size() <= 128);
    }

    // Athlete namespace: Users and subcollections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);

      match /exercises/{exerciseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidId(exerciseId) && isValidExercise(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(exerciseId);
      }

      match /history/{workoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidId(workoutId) && isValidWorkout(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(workoutId);
      }

      match /routines/{routineId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidId(routineId) && isValidRoutine(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(routineId);
      }

      match /weights/{weightId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidId(weightId) && isValidWeightEntry(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(weightId);
      }
    }
  }
}
